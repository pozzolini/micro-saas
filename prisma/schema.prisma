generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id    Int    @id @default(autoincrement())
  name  String
  slug  String @unique
  users User[]
}

model User {
  id             Int           @id @default(autoincrement())
  name           String
  email          String        @unique
  passwordHash   String
  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])
}
